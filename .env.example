# Public URL for calendar subscribe/download links (required in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics (optional locally; defaults to project ID if unset)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BYRPBMKJ6M

# Google AdSense (optional — defaults to project publisher ID if unset)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-1647869340518438
# NEXT_PUBLIC_ADSENSE_SLOT_ID=xxxxxxxx

# Live results feed (optional — defaults to fixturedownload FIFA feed)
# LIVE_FEED_URL=https://fixturedownload.com/feed/json/fifa-world-cup-2026

# Cron secret for /api/cron/refresh (set in Vercel for production)
# CRON_SECRET=your-random-secret
