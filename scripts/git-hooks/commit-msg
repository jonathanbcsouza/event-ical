#!/bin/sh
# Rejects commit messages that still contain editor/agent attribution.

MSG_FILE=$1

[ -f "$MSG_FILE" ] || exit 0

if grep -qiE \
  '(^co-authored-by:.*cursor|^co-authored-by:.*cursoragent@|^made with cursor|^generated by cursor|^signed-off-by:.*cursor)' \
  "$MSG_FILE"; then
  echo "Commit blocked: remove automated co-author lines from the message." >&2
  exit 1
fi

if ! head -1 "$MSG_FILE" | grep -qE '^(feat|fix|chore|docs|refactor|test|ci|build)(\([a-z0-9-]+\))?: .{1,72}$'; then
  echo "Commit blocked: use Conventional Commits — type(scope): subject" >&2
  echo "Example: feat(ui): add calendar view" >&2
  exit 1
fi

exit 0
