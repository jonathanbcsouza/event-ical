#!/bin/sh
# Strips automated co-author trailers before the commit message is finalized.

MSG_FILE=$1

[ -f "$MSG_FILE" ] || exit 0

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

grep -viE \
  '(^co-authored-by:.*cursor|^co-authored-by:.*cursoragent@|^made with cursor|^generated by cursor|^signed-off-by:.*cursor)' \
  "$MSG_FILE" > "$tmp" || true

mv "$tmp" "$MSG_FILE"
trap - EXIT

exit 0
